#!/usr/bin/env bash
set -euo pipefail

COMPOSE_FILE="$(cd "$(dirname "$0")" && pwd)/docker-compose.yml"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
TAILSCALE_LAST_STATUS=""
STACK_CONTAINERS=(vllm ai-chat-vllm)
RUNTIME_ENV_FILE="$PROJECT_DIR/.runtime-model.env"
MODEL_MARKERS_DIR="$PROJECT_DIR/data/models"
MODEL_STATE_FILE="$PROJECT_DIR/data/model_state.json"
HF_CACHE_ROOT="${HF_HOME:-$HOME/.cache/huggingface}"
FRONTEND_SOURCE_FILE="$PROJECT_DIR/src/web/app.ts"
FRONTEND_BUNDLE_FILE="$PROJECT_DIR/src/web/app.js"
FRONTEND_BUILD_SCRIPT="$PROJECT_DIR/scripts/build_frontend.mjs"
FRONTEND_PACKAGE_FILE="$PROJECT_DIR/package.json"
FRONTEND_BUNDLE_CHANGED=0

DEFAULT_14B_MODEL_NAME="${MODEL_14B_NAME:-Qwen/Qwen3-14B-AWQ}"
DEFAULT_14B_MODEL_ARGS="${MODEL_14B_ARGS:---gpu-memory-utilization 0.95 --max-model-len 8192 --enable-prefix-caching --max-num-seqs 16 --enable-chunked-prefill --quantization awq_marlin --trust-remote-code --enforce-eager}"
DEFAULT_8B_MODEL_NAME="${MODEL_8B_NAME:-meta-llama/Meta-Llama-3.1-8B-Instruct}"
DEFAULT_8B_MODEL_ARGS="${MODEL_8B_ARGS:---gpu-memory-utilization 0.90 --max-model-len 8192 --enable-prefix-caching --max-num-seqs 16 --enable-chunked-prefill --enforce-eager}"

cd "$PROJECT_DIR"

model_profile_keys() {
    printf '%s\n' "14b" "8b"
}

model_profile_label() {
    case "$1" in
        14b) printf '%s\n' "14B" ;;
        8b) printf '%s\n' "8B" ;;
        *) return 1 ;;
    esac
}

model_profile_name() {
    case "$1" in
        14b) printf '%s\n' "$DEFAULT_14B_MODEL_NAME" ;;
        8b) printf '%s\n' "$DEFAULT_8B_MODEL_NAME" ;;
        *) return 1 ;;
    esac
}

model_profile_args() {
    case "$1" in
        14b) printf '%s\n' "$DEFAULT_14B_MODEL_ARGS" ;;
        8b) printf '%s\n' "$DEFAULT_8B_MODEL_ARGS" ;;
        *) return 1 ;;
    esac
}

model_cache_path() {
    local model_name="$1"
    local encoded="${model_name//\//--}"
    printf '%s\n' "$HF_CACHE_ROOT/hub/models--$encoded"
}

model_profile_cached() {
    local profile="$1"
    local model_name
    model_name="$(model_profile_name "$profile")"
    [[ -d "$(model_cache_path "$model_name")" ]]
}

model_profile_recorded_in_state() {
    local profile="$1"
    local model_name
    model_name="$(model_profile_name "$profile")"
    [[ -f "$MODEL_STATE_FILE" ]] && grep -Fq "\"$model_name\"" "$MODEL_STATE_FILE"
}

model_marker_path() {
    printf '%s\n' "$MODEL_MARKERS_DIR/$1.installed"
}

ensure_runtime_env_file() {
    mkdir -p "$MODEL_MARKERS_DIR"
    if [[ ! -f "$RUNTIME_ENV_FILE" ]]; then
        write_runtime_env_file "14b"
    fi
}

write_runtime_env_file() {
    local profile="$1"
    local model_name model_args
    model_name="$(model_profile_name "$profile")"
    model_args="$(model_profile_args "$profile")"
    cat >"$RUNTIME_ENV_FILE" <<EOF
VLLM_SELECTED_PROFILE=$profile
VLLM_SELECTED_MODEL_NAME=$model_name
VLLM_SELECTED_MODEL_ARGS=$model_args
EOF
}

current_runtime_profile() {
    if [[ ! -f "$RUNTIME_ENV_FILE" ]]; then
        printf '%s\n' ""
        return 0
    fi
    awk -F= '$1=="VLLM_SELECTED_PROFILE"{print $2; exit}' "$RUNTIME_ENV_FILE"
}

model_profile_installed() {
    local profile="$1"
    [[ -f "$(model_marker_path "$profile")" ]] \
        || model_profile_cached "$profile" \
        || model_profile_recorded_in_state "$profile"
}

mark_model_installed() {
    local profile="$1"
    mkdir -p "$MODEL_MARKERS_DIR"
    printf '%s\n' "$(model_profile_name "$profile")" >"$(model_marker_path "$profile")"
}

list_installed_model_profiles() {
    local key
    for key in $(model_profile_keys); do
        if model_profile_installed "$key"; then
            printf '%s\n' "$key"
        fi
    done
}

download_model_profile() {
    local profile="$1"
    local model_name
    model_name="$(model_profile_name "$profile")"
    if model_profile_installed "$profile"; then
        echo "$(model_profile_label "$profile") already downloaded."
        return 0
    fi
    echo "Downloading $(model_profile_label "$profile") model cache for $model_name ..."
    docker run --rm \
        -v "$HOME/.cache/huggingface:/root/.cache/huggingface" \
        --entrypoint python \
        vllm/vllm-openai:latest \
        -c "from huggingface_hub import snapshot_download; snapshot_download(repo_id='$model_name', resume_download=True)"
    mark_model_installed "$profile"
    echo "Downloaded $(model_profile_label "$profile")."
}

# Filter known benign Docker/Colima transport noise while preserving real errors.
docker_compose() {
    local -a compose_cmd
    ensure_runtime_env_file
    if docker compose version >/dev/null 2>&1; then
        compose_cmd=(docker compose)
    elif command -v docker-compose >/dev/null 2>&1; then
        compose_cmd=(docker-compose)
    else
        echo "ERROR: Docker Compose is unavailable. Install the Docker Compose v2 plugin or the docker-compose binary." >&2
        exit 1
    fi

    "${compose_cmd[@]}" --env-file "$RUNTIME_ENV_FILE" -f "$COMPOSE_FILE" --project-directory "$PROJECT_DIR" "$@" 2> >(
        awk '
            /^channel [0-9]+: open failed: connect failed: Connection refused$/ { next }
            /^\[\+\] Pulling [0-9]+\/[0-9]+ failed: connect failed: Connection refused$/ { next }
            { print > "/dev/stderr" }
        '
    )
}

stack_container_exists() {
    docker inspect "$1" >/dev/null 2>&1
}

list_existing_stack_containers() {
    local container
    for container in "${STACK_CONTAINERS[@]}"; do
        if stack_container_exists "$container"; then
            printf '%s\n' "$container"
        fi
    done
}

remove_existing_stack_containers() {
    local container
    for container in "${STACK_CONTAINERS[@]}"; do
        if stack_container_exists "$container"; then
            docker rm -f "$container" >/dev/null 2>&1 || true
            if ! stack_container_exists "$container"; then
                printf '%s\n' "$container"
            fi
        fi
    done
}

print_container_list() {
    local containers="$1"
    local container
    while IFS= read -r container; do
        [[ -n "$container" ]] || continue
        echo "  - $container"
    done <<< "$containers"
}

ensure_stack_stopped() {
    local context="$1"
    local compose_failed=0
    local removed=""
    local remaining=""

    if ! docker_compose down --remove-orphans; then
        compose_failed=1
        echo "Compose reported an issue while ${context}; checking containers directly..."
    fi

    removed="$(remove_existing_stack_containers)"
    if [[ -n "$removed" ]]; then
        echo "Removed leftover containers directly:"
        print_container_list "$removed"
    fi

    remaining="$(list_existing_stack_containers)"
    if [[ -n "$remaining" ]]; then
        echo "ERROR: These containers are still present:"
        print_container_list "$remaining"
        return 1
    fi

    if [[ "$compose_failed" -eq 1 && -z "$removed" ]]; then
        echo "ERROR: Docker Compose reported a shutdown issue."
        return 1
    fi
}

# Get the LAN IP address of the host
lan_ip() {
    hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost"
}

app_port() {
    printf '%s\n' "${APP_PORT:-${PORT:-8000}}"
}

app_scheme() {
    if [[ -n "${SSL_CERTFILE:-}" && -n "${SSL_KEYFILE:-}" ]]; then
        printf '%s\n' "https"
    else
        printf '%s\n' "http"
    fi
}

tailscale_available() {
    command -v tailscale >/dev/null 2>&1
}

tailscale_manage_mode() {
    printf '%s\n' "${TAILSCALE_SERVE:-off}"
}

tailscale_should_manage() {
    case "$(tailscale_manage_mode)" in
        auto|on|true|1|enabled)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

tailscale_https_port() {
    printf '%s\n' "${TAILSCALE_SERVE_HTTPS_PORT:-$(app_port)}"
}

tailscale_target_url() {
    local scheme port
    scheme="$(app_scheme)"
    port="$(app_port)"
    if [[ "$scheme" == "https" ]]; then
        printf '%s\n' "https+insecure://127.0.0.1:${port}"
    else
        printf '%s\n' "http://127.0.0.1:${port}"
    fi
}

extract_tailscale_https_url() {
    local https_port="$1"
    if [[ "$https_port" == "443" ]]; then
        sed -nE 's#.*(https://[^[:space:]]+).*#\1#p' | awk 'NF { print; exit }'
    else
        sed -nE "s#.*(https://[^[:space:]]+:${https_port}).*#\\1#p" | awk 'NF { print; exit }'
    fi
}

tailscale_serve_https_url() {
    local https_port status
    if ! tailscale_available; then
        return 0
    fi
    https_port="$(tailscale_https_port)"
    status="$(tailscale serve status 2>/dev/null || true)"
    if [[ -z "$status" ]]; then
        return 0
    fi
    printf '%s\n' "$status" | extract_tailscale_https_url "$https_port"
}

ensure_tailscale_https() {
    local https_port target output
    TAILSCALE_LAST_STATUS=""

    if ! tailscale_should_manage || ! tailscale_available; then
        return 1
    fi

    https_port="$(tailscale_https_port)"
    target="$(tailscale_target_url)"

    if output="$(tailscale serve --bg --yes --https="${https_port}" "$target" 2>&1)"; then
        TAILSCALE_LAST_STATUS="tailnet HTTPS enabled"
        return 0
    fi

    TAILSCALE_LAST_STATUS="$(printf '%s\n' "$output" | awk 'NF { print; exit }')"
    return 1
}

disable_tailscale_https() {
    local https_port
    if ! tailscale_should_manage || ! tailscale_available; then
        return 0
    fi
    https_port="$(tailscale_https_port)"
    tailscale serve --https="${https_port}" off >/dev/null 2>&1 || true
}

preferred_browser_url() {
    local tailscale_https
    tailscale_https="$(tailscale_serve_https_url)"
    if [[ -n "$tailscale_https" ]]; then
        printf '%s\n' "$tailscale_https"
        return 0
    fi

    printf '%s\n' "$(app_scheme)://localhost:$(app_port)"
}

print_access_urls() {
    local preferred local_url
    preferred="$(preferred_browser_url)"
    local_url="$(app_scheme)://localhost:$(app_port)"

    echo "  Open:     ${preferred}"
    if [[ "$preferred" != "$local_url" ]]; then
        echo "  Local:    ${local_url}"
    fi
    if [[ -n "$TAILSCALE_LAST_STATUS" && "$preferred" == "$local_url" ]]; then
        echo "  Tailnet:  ${TAILSCALE_LAST_STATUS}"
    fi
}

open_url_in_browser() {
    local url="$1"
    if command -v open >/dev/null 2>&1; then
        open "$url"
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url"
    else
        echo "No supported browser opener found. Open this URL manually:"
        echo "$url"
        return 1
    fi
}

usage() {
    echo "Usage: ./chat {install|start|stop|restart|status|logs|open}..."
    echo ""
    echo "Commands:"
    echo "  install   Build images, pull dependencies, and download the default model"
    echo "  start     Start all services with the installed/default model (idempotent)"
    echo "  stop      Stop all services and clean up (idempotent)"
    echo "  restart   Stop then start"
    echo "  status    Show running containers"
    echo "  logs      Tail logs from all services"
    echo "  open      Open the preferred browser URL"
}

default_model_profile() {
    local profile="${DEFAULT_MODEL_PROFILE:-}"
    case "$profile" in
        14b|8b)
            printf '%s\n' "$profile"
            ;;
        *)
            printf '%s\n' "14b"
            ;;
    esac
}

install_target_profile() {
    local current_profile
    current_profile="$(current_runtime_profile)"
    if [[ -n "$current_profile" ]]; then
        case "$current_profile" in
            14b|8b)
                printf '%s\n' "$current_profile"
                return 0
                ;;
        esac
    fi
    default_model_profile
}

resolve_installed_profile_noninteractive() {
    local preferred="$1"
    shift || true
    local -a profiles=("$@")
    local profile

    for profile in "${profiles[@]}"; do
        if [[ "$profile" == "$preferred" ]]; then
            printf '%s\n' "$profile"
            return 0
        fi
    done

    for profile in "${profiles[@]}"; do
        if [[ "$profile" == "$(default_model_profile)" ]]; then
            printf '%s\n' "$profile"
            return 0
        fi
    done

    if [[ "${#profiles[@]}" -gt 0 ]]; then
        printf '%s\n' "${profiles[0]}"
        return 0
    fi

    return 1
}

ensure_data_dirs() {
    # Pre-create data directories before Docker can claim them as root
    mkdir -p "$MODEL_MARKERS_DIR"
}

frontend_bundle_signature() {
    local target="$1"
    if [[ ! -f "$target" ]]; then
        printf '%s\n' "missing"
        return 0
    fi
    cksum "$target" | awk '{print $1 ":" $2}'
}

frontend_build_required() {
    [[ ! -f "$FRONTEND_BUNDLE_FILE" ]] && return 0
    [[ "$FRONTEND_SOURCE_FILE" -nt "$FRONTEND_BUNDLE_FILE" ]] && return 0
    [[ "$FRONTEND_BUILD_SCRIPT" -nt "$FRONTEND_BUNDLE_FILE" ]] && return 0
    [[ "$FRONTEND_PACKAGE_FILE" -nt "$FRONTEND_BUNDLE_FILE" ]] && return 0
    return 1
}

build_frontend_bundle() {
    FRONTEND_BUNDLE_CHANGED=0
    if ! frontend_build_required; then
        echo "TypeScript frontend bundle is up to date."
        return 0
    fi
    if ! command -v node >/dev/null 2>&1; then
        echo "ERROR: Node.js is required to build src/web/app.ts into src/web/app.js." >&2
        exit 1
    fi
    if ! command -v npm >/dev/null 2>&1; then
        echo "ERROR: npm is required to build the frontend bundle." >&2
        exit 1
    fi

    local before after
    before="$(frontend_bundle_signature "$FRONTEND_BUNDLE_FILE")"
    echo "Building TypeScript frontend..."
    npm run build:frontend
    after="$(frontend_bundle_signature "$FRONTEND_BUNDLE_FILE")"
    if [[ "$before" != "$after" ]]; then
        FRONTEND_BUNDLE_CHANGED=1
    fi
}

do_install() {
    ensure_data_dirs
    build_frontend_bundle
    echo ""
    echo "Pulling vLLM image..."
    docker_compose pull vllm
    echo ""
    echo "Building chat-app image..."
    docker_compose build chat-app
    echo ""
    local selected_profile
    selected_profile="$(install_target_profile)"
    write_runtime_env_file "$selected_profile"
    echo "Preparing $(model_profile_label "$selected_profile") as the default downloaded model..."
    download_model_profile "$selected_profile"
    echo ""
    echo "Install complete. Run './chat start' to launch."
}

do_start() {
    ensure_data_dirs
    build_frontend_bundle
    mapfile -t installed_profiles < <(list_installed_model_profiles)
    if [[ "${#installed_profiles[@]}" -eq 0 ]]; then
        echo "No downloaded models were found. Run './chat install' first."
        exit 1
    fi

    local current_profile selected_profile
    current_profile="$(current_runtime_profile)"
    selected_profile="$(resolve_installed_profile_noninteractive "$current_profile" "${installed_profiles[@]}")"
    write_runtime_env_file "$selected_profile"

    # Check if already fully running
    local vllm_running chat_running
    vllm_running=$(docker inspect -f '{{.State.Running}}' vllm 2>/dev/null || echo "false")
    chat_running=$(docker inspect -f '{{.State.Running}}' ai-chat-vllm 2>/dev/null || echo "false")

    if [[ "$vllm_running" == "true" && "$chat_running" == "true" ]]; then
        if [[ "$current_profile" == "$selected_profile" && "$FRONTEND_BUNDLE_CHANGED" -eq 0 ]]; then
            ensure_tailscale_https || true
            echo "Already running."
            print_access_urls
            return 0
        fi
        if [[ "$current_profile" != "$selected_profile" ]]; then
            echo "Switching to $(model_profile_label "$selected_profile") for this session..."
        fi
        if [[ "$FRONTEND_BUNDLE_CHANGED" -eq 1 ]]; then
            echo "Frontend bundle changed; restarting chat-app with the rebuilt assets..."
        fi
    fi

    # Clean up any stopped/broken containers before starting
    ensure_stack_stopped "cleaning up before start"

    if [[ "$FRONTEND_BUNDLE_CHANGED" -eq 1 ]]; then
        echo "Rebuilding chat-app image to include the latest frontend bundle..."
        docker_compose build chat-app
    fi

    echo "Starting services..."
    docker_compose up -d

    ensure_tailscale_https || true

    echo ""
    echo "Started."
    print_access_urls
    echo ""
    echo "Running $(model_profile_label "$selected_profile") for this session."
    echo "Note: vLLM may take a few minutes to load the selected model on first run."
    echo "Run './chat logs' to watch progress."
}

do_stop() {
    echo "Stopping services..."
    ensure_stack_stopped "stopping services"
    disable_tailscale_https
    echo "Stopped."
}

do_status() {
    local vllm_state chat_state
    vllm_state=$(docker inspect -f '{{.State.Status}}' vllm 2>/dev/null || echo "not found")
    chat_state=$(docker inspect -f '{{.State.Status}}' ai-chat-vllm 2>/dev/null || echo "not found")
    echo "  vLLM:       $vllm_state"
    echo "  chat-app:   $chat_state"
    if [[ "$chat_state" == "running" ]]; then
        TAILSCALE_LAST_STATUS=""
        echo ""
        print_access_urls
    fi
}

do_open() {
    local url
    url="$(preferred_browser_url)"
    echo "Opening $url"
    open_url_in_browser "$url"
}

if [[ "$#" -eq 0 ]]; then
    usage
    exit 1
fi

while [[ "$#" -gt 0 ]]; do
    case "$1" in
        install)  do_install ;;
        start)    do_start ;;
        stop)     do_stop ;;
        restart)  do_stop; echo ""; do_start ;;
        status)   do_status ;;
        logs)     docker_compose logs -f ;;
        open)     do_open ;;
        *)        usage; exit 1 ;;
    esac
    shift
    if [[ "$#" -gt 0 ]]; then
        echo ""
    fi
done
