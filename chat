#!/usr/bin/env bash
set -euo pipefail

COMPOSE_FILE="$(cd "$(dirname "$0")" && pwd)/docker-compose.yml"
PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"

cd "$PROJECT_DIR"

# Filter known benign Docker/Colima transport noise while preserving real errors.
docker_compose() {
    local -a compose_cmd
    if docker compose version >/dev/null 2>&1; then
        compose_cmd=(docker compose)
    elif command -v docker-compose >/dev/null 2>&1; then
        compose_cmd=(docker-compose)
    else
        echo "ERROR: Docker Compose is unavailable. Install the Docker Compose v2 plugin or the docker-compose binary." >&2
        exit 1
    fi

    "${compose_cmd[@]}" "$@" 2> >(
        awk '
            /^channel [0-9]+: open failed: connect failed: Connection refused$/ { next }
            /^\[\+\] Pulling [0-9]+\/[0-9]+ failed: connect failed: Connection refused$/ { next }
            { print > "/dev/stderr" }
        '
    )
}

# Get the LAN IP address of the host
lan_ip() {
    hostname -I 2>/dev/null | awk '{print $1}' || echo "localhost"
}

usage() {
    echo "Usage: ./chat {install|start|stop|restart|status|logs|learn|export-training|train-router|train-tool-policy|backfill-evaluations}"
    echo ""
    echo "Commands:"
    echo "  install   Build images and pull dependencies"
    echo "  start     Start all services (idempotent)"
    echo "  stop      Stop all services and clean up (idempotent)"
    echo "  restart   Stop then start"
    echo "  status    Show running containers"
    echo "  logs      Tail logs from all services"
    echo "  learn     Run the full lightweight learning loop against the latest chat.db"
    echo "  export-training [out_dir]  Export JSONL training datasets from data/chat.db"
    echo "  train-router [input_jsonl] [output_json]  Train a lightweight workflow router"
    echo "  train-tool-policy [input_jsonl] [output_json]  Train a lightweight tool-family helper"
    echo "  backfill-evaluations       Recompute workflow_evaluations for existing executions"
}

ensure_data_dirs() {
    # Pre-create data directories before Docker can claim them as root
    mkdir -p "$PROJECT_DIR/data/voice/models"
}

install_voice_model() {
    local model_dir="$PROJECT_DIR/data/voice/models"
    local model_name="en_US-lessac-high"
    local model_file="$model_dir/${model_name}.onnx"
    local config_file="$model_dir/${model_name}.onnx.json"
    local base_url="https://huggingface.co/rhasspy/piper-voices/resolve/main/en/en_US/lessac/high"

    if [[ -f "$model_file" && -f "$config_file" ]]; then
        echo "Piper voice model already installed."
        return 0
    fi

    echo "Downloading Piper TTS voice model..."
    if ! mkdir -p "$model_dir" 2>/dev/null; then
        echo ""
        echo "ERROR: Cannot write to $model_dir"
        echo "Docker likely created it as root. Fix with:"
        echo "  sudo chown -R $(id -un):$(id -gn) $PROJECT_DIR/data"
        echo "Then re-run: ./chat install"
        exit 1
    fi
    curl -fSL "$base_url/${model_name}.onnx" -o "$model_file"
    curl -fSL "$base_url/${model_name}.onnx.json" -o "$config_file"
    echo "Voice model downloaded."
}

do_install() {
    ensure_data_dirs
    echo "Pulling vLLM image..."
    docker_compose pull vllm
    echo ""
    echo "Building chat-app image..."
    docker_compose build chat-app
    echo ""
    echo "Installing voice tools..."
    install_voice_model
    echo ""
    echo "Install complete. Run './chat start' to launch."
}

do_start() {
    ensure_data_dirs
    # Check if already fully running
    local vllm_running chat_running
    vllm_running=$(docker inspect -f '{{.State.Running}}' vllm 2>/dev/null || echo "false")
    chat_running=$(docker inspect -f '{{.State.Running}}' ai-chat-vllm 2>/dev/null || echo "false")

    if [[ "$vllm_running" == "true" && "$chat_running" == "true" ]]; then
        echo "Already running."
        echo "  Local:    http://localhost:8000"
        echo "  LAN:      http://$(lan_ip):8000"
        return 0
    fi

    # Clean up any stopped/broken containers before starting
    docker_compose down --remove-orphans 2>/dev/null || true

    echo "Starting services..."
    docker_compose up -d

    echo ""
    echo "Started."
    echo "  Local:    http://localhost:8000"
    echo "  LAN:      http://$(lan_ip):8000"
    echo ""
    echo "Note: vLLM may take a few minutes to load the model on first run."
    echo "Run './chat logs' to watch progress."
}

do_stop() {
    echo "Stopping services..."
    docker_compose down --remove-orphans 2>/dev/null || true
    echo "Stopped."
}

do_status() {
    local vllm_state chat_state
    vllm_state=$(docker inspect -f '{{.State.Status}}' vllm 2>/dev/null || echo "not found")
    chat_state=$(docker inspect -f '{{.State.Status}}' ai-chat-vllm 2>/dev/null || echo "not found")
    echo "  vLLM:       $vllm_state"
    echo "  chat-app:   $chat_state"
}

do_export_training() {
    local out_dir="${1:-$PROJECT_DIR/training/exports/latest}"
    mkdir -p "$PROJECT_DIR/training/exports"
    python3 "$PROJECT_DIR/training/export_workflow_dataset.py" \
        --db-path "$PROJECT_DIR/data/chat.db" \
        --out-dir "$out_dir"
}

do_train_router() {
    local input_path="${1:-$PROJECT_DIR/training/exports/latest/router_examples.jsonl}"
    local output_path="${2:-$PROJECT_DIR/data/router_model.json}"
    python3 "$PROJECT_DIR/training/train_router.py" \
        --input "$input_path" \
        --output "$output_path"
}

do_train_tool_policy() {
    local input_path="${1:-$PROJECT_DIR/training/exports/latest/workflow_traces.jsonl}"
    local output_path="${2:-$PROJECT_DIR/data/tool_policy_model.json}"
    python3 "$PROJECT_DIR/training/train_tool_policy.py" \
        --input "$input_path" \
        --output "$output_path"
}

do_backfill_evaluations() {
    python3 "$PROJECT_DIR/training/backfill_workflow_evaluations.py" \
        --db-path "$PROJECT_DIR/data/chat.db"
}

do_learn() {
    local export_dir="${1:-$PROJECT_DIR/training/exports/latest}"
    local router_model="${2:-$PROJECT_DIR/data/router_model.json}"
    local tool_policy_model="${3:-$PROJECT_DIR/data/tool_policy_model.json}"

    echo "==> Backfilling workflow evaluations"
    do_backfill_evaluations
    echo ""

    echo "==> Exporting training datasets"
    do_export_training "$export_dir"
    echo ""

    echo "==> Training workflow router"
    do_train_router "$export_dir/router_examples.jsonl" "$router_model"
    echo ""

    echo "==> Training tool policy helper"
    do_train_tool_policy "$export_dir/workflow_traces.jsonl" "$tool_policy_model"
    echo ""

    echo "Learning loop complete."
    echo "  Export dir:        $export_dir"
    echo "  Router model:      $router_model"
    echo "  Tool policy model: $tool_policy_model"
    echo ""
    echo "This refreshes the lightweight learned helpers from the latest chat history."
    echo "It does not finetune the main chat model yet."
}

case "${1:-}" in
    install)  do_install ;;
    start)    do_start ;;
    stop)     do_stop ;;
    restart)  do_stop; echo ""; do_start ;;
    status)   do_status ;;
    logs)     docker_compose logs -f ;;
    learn)    shift; do_learn "${1:-}" "${2:-}" "${3:-}" ;;
    export-training) shift; do_export_training "${1:-}" ;;
    train-router) shift; do_train_router "${1:-}" "${2:-}" ;;
    train-tool-policy) shift; do_train_tool_policy "${1:-}" "${2:-}" ;;
    backfill-evaluations) do_backfill_evaluations ;;
    *)        usage; exit 1 ;;
esac
